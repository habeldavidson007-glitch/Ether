```gitignore
# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Logs and temp files
*.log
*.tmp
*.swp

# Environment files
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Build artifacts
*.o
*.obj
*.so
*.dll
*.exe
*.a
*.out

# Coverage reports
coverage/
htmlcov/
.coverage

# Dependencies
node_modules/
venv/
.venv/
.mypy_cache/
.pytest_cache/
dist/
build/
target/
.gradle/
```