```gitignore
# Python compiled files
*.pyc
__pycache__/

# Dependencies
.venv/
venv/
node_modules/

# Logs and temporary files
*.log
*.tmp
*.swp

# Environment files
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Coverage reports
coverage/
htmlcov/
.coverage

# MyPy cache
.mypy_cache/

# Pytest cache
.pytest_cache/
```