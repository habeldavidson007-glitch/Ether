```gitignore
# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Dependencies
venv/
.venv/
env/
.ENV/

# Testing
.pytest_cache/
.coverage
coverage/

# Logs
*.log

# Environment variables
.env
.env.local
*.env.*

# Editor files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# OS generated files
.DS_Store
Thumbs.db
```