```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Virtual environments
venv/
.venv/
env/

# Logs
*.log

# Environment files
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/

# Temporary files
*.tmp
*.swp

# Coverage reports
.coverage
coverage/
htmlcov/

# Build artifacts
build/
dist/
*.egg-info/

# Python cache
.mypy_cache/
.pytest_cache/

# OS generated files
.DS_Store
Thumbs.db
```