{
  "services": [
    {
      "name": "knowledge_daemon",
      "script": "/workspace/courier/daemon.py",
      "args": [
        "--interval",
        "3600"
      ],
      "auto_restart": true,
      "cpu_limit": 20.0,
      "ram_limit_mb": 256
    },
    {
      "name": "rag_indexer",
      "script": "/workspace/core/rag_index.py",
      "args": [
        "--watch"
      ],
      "auto_restart": true,
      "cpu_limit": 30.0,
      "ram_limit_mb": 512
    },
    {
      "name": "memory_core",
      "script": "/workspace/core/memory_core.py",
      "args": [
        "--background"
      ],
      "auto_restart": true,
      "cpu_limit": 15.0,
      "ram_limit_mb": 128
    }
  ]
}